{
  "expo": {
    "name": "Tailor's Ledger",
    "slug": "tailors-ledger",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tailorsledger",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.tailorsledger"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false,
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so"
              ]
            }
          },
          "ios": {
            "newArchEnabled": false
          }
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Tailor's Ledger to attach photos to a measurement set.",
          "cameraPermission": "Allow Tailor's Ledger to take photos of a measurement card or garment."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Unlock Tailor's Ledger with Face ID."
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "backendBaseUrl": "https://tailors-ledger-be.onrender.com/v1",
      "supabaseUrl": "https://enywrjcebqbhendeaswx.supabase.co",
      "supabaseAnonKey": "sb_publishable_ZBj8m_kF-c_h3x7mUEOjuw_b38pGagx"
    }
  }
}
